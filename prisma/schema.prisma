generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  name      String
  role      Role     @default(visitor)
  password  String
  events    Event[]
}

model Event {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  title          String
  description    String
  date           DateTime
  venue          String
  city           String
  price          Float
  totalSeats     Int
  availableSeats Int
  category       Category
  image          String?
  organizerId    Int
  organizer      User     @relation(fields: [organizerId], references: [id])
}

enum Role {
  visitor
  user
  admin
  orga
}

enum Category {
  Concert
  Conference
  Festival
  Sport
  Theatre
  Autre
} 